# =============================================================================
# Файл настроек vpconnect-manage (формат KEY=value).
# Подхватывается при старте через manage_site/settings.py (переменная ENV_FILENAME).
# Полный смысл параметров — в README.md, раздел «Переменные settings.env».
# Секреты и пути на сервере не коммитьте в открытый репозиторий.
# =============================================================================

# --- Веб-приложение Flask ---
# Секрет подписи cookie сессии; в продакшене — длинная случайная строка.
FLASK_SECRET_KEY=dev-selfvpn-change-in-production-to-long-random-secret

# Пароль администратора для первичного создания admin_user.json и кнопки «Сбросить» в UI (опционально).
ADMIN_DEFAULT_PASSWORD=

# Блокировка входа после неверных попыток с одного IP.
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=60

# --- WireGuard (пустой WIREGUARD_CONF_PATH = интеграция выключена, секция клиентов в UI скрыта) ---
# Абсолютный или ~ путь к wg0.conf на сервере (часто /etc/wireguard/wg0.conf).
WIREGUARD_CONF_PATH=

# Интервал фоновой синхронизации vpn_clients.json с wg0.conf, минуты. 0 — только при старте и при открытии дашборда.
WIREGUARD_SYNC_INTERVAL_MINUTES=5

# Имя интерфейса для wg-quick strip / wg syncconf (имя файла без .conf в /etc/wireguard/).
WIREGUARD_INTERFACE_NAME=wg0

# Полный Endpoint для клиентских .conf (host:port). Если задан — WIREGUARD_PUBLIC_HOST и порт ниже для Endpoint не используются.
WIREGUARD_ENDPOINT=

# Публичный FQDN или IP сервера для клиентов (если WIREGUARD_ENDPOINT пуст — порт из ListenPort в wg0.conf или см. ниже).
WIREGUARD_PUBLIC_HOST=

# Порт UDP для Endpoint при пустом WIREGUARD_ENDPOINT: 0 = взять ListenPort из wg0.conf, иначе при отсутствии — 51820.
WIREGUARD_LISTEN_PORT=0

# DNS в клиентском [Interface].
WIREGUARD_DNS=8.8.8.8

# Каталог для клиентских *.conf (и подкаталог qr). Пусто = <родитель WIREGUARD_CLIENT_KEYS_DIR>/client_config.
WIREGUARD_CLIENT_CONFIG_DIR=

# --- Ключи и MTProxy ---
# Каталог ключей клиентов WireGuard на сервере. Пусто = manage_site/data/vpn_client_keys относительно корня репозитория (см. README про cwd).
WIREGUARD_CLIENT_KEYS_DIR=

# Путь к файлу со ссылкой MTProxy (первая непустая строка). Пусто = секция MTProxy в UI скрыта.
MTPROXY_LINK_FILE=
